  "semanticHighlighting": true,
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment",
        "string.comment"
      ],
      "settings": {
        "foreground": "#707085"
      }
    },
    {
      "scope": [
        "constant.other.placeholder",
        "constant.character"
      ],
      "settings": {
        "foreground": "#D19A66"
      }
    },
    {
      "scope": [
        "constant",
        "entity.name.constant",
        "variable.other.constant",
        "variable.other.enummember",
        "variable.language",
        "entity"
      ],
      "settings": {
        "foreground": "#D19A66"
      }
    },
    {
      "scope": [
        "entity.name",
        "meta.export.default",
        "meta.definition.variable"
      ],
      "settings": {
        "foreground": "#E5C07B"
      }
    },
    {
      "scope": [
        "variable.parameter.function",
        "meta.jsx.children",
        "meta.block",
        "meta.tag.attributes",
        "entity.name.constant",
        "meta.object.member",
        "meta.embedded.expression"
      ],
      "settings": {
        "foreground": "#E8E8EF"
      }
    },
    {
      "scope": "meta.jsx.children",
      "settings": {
        "foreground": "#E8E8EF"
      }
    },
    {
      "scope": "entity.name.function",
      "settings": {
        "foreground": "#61AFEF"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "support.class.component"
      ],
      "settings": {
        "foreground": "#E06B74"
      }
    },
    {
      "scope": "keyword",
      "settings": {
        "foreground": "#C678DD"
      }
    },
    {
      "scope": [
        "storage",
        "storage.type"
      ],
      "settings": {
        "foreground": "#C678DD"
      }
    },
    {
      "scope": [
        "storage.modifier.package",
        "storage.modifier.import",
        "storage.type.java"
      ],
      "settings": {
        "foreground": "#C678DD"
      }
    },
    {
      "scope": [
        "string",
        "string punctuation.section.embedded source"
      ],
      "settings": {
        "foreground": "#7EC699"
      }
    },
    {
      "scope": "support",
      "settings": {
        "foreground": "#61AFEF"
      }
    },
    {
      "scope": "meta.property-name",
      "settings": {
        "foreground": "#E06B74"
      }
    },
    {
      "scope": "variable",
      "settings": {
        "foreground": "#E8E8EF"
      }
    },
    {
      "scope": "variable.other",
      "settings": {
        "foreground": "#E06B74"
      }
    },
    {
      "scope": "invalid.broken",
      "settings": {
        "foreground": "#F65866"
      }
    },
    {
      "scope": "invalid.deprecated",
      "settings": {
        "foreground": "#F65866"
      }
    },
    {
      "scope": "invalid.illegal",
      "settings": {
        "foreground": "#F65866"
      }
    },
    {
      "scope": "invalid.unimplemented",
      "settings": {
        "foreground": "#F65866"
      }
    },
    {
      "scope": "carriage-return",
      "settings": {
        "background": "#F65866",
        "foreground": "#FFFFFF",
        "content": "^M"
      }
    },
    {
      "scope": "message.error",
      "settings": {
        "foreground": "#F65866"
      }
    },
    {
      "scope": "string variable",
      "settings": {
        "foreground": "#61AFEF"
      }
    },
    {
      "scope": [
        "source.regexp",
        "string.regexp"

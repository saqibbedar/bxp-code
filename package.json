{
  "name": "bxp-code",
  "version": "1.0.0",
  "description": "Drop-in React code blocks with Shiki highlighting, Prettier formatting, and zero config.",
  "author": {
    "name": "Saqib Bedar"
  },
  "license": "MIT",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "keywords": [
    "react",
    "react-component",
    "code-block",
    "code-highlight",
    "syntax-highlighting",
    "shiki",
    "prettier",
    "code-formatting",
    "dark-theme",
    "light-theme",
    "typescript",
    "javascript",
    "code-viewer",
    "code-snippet",
    "copy-to-clipboard",
    "line-numbers",
    "tabs",
    "zero-config"
  ],
  "scripts": {
    "dev": "vite",
    "host": "vite --host",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "prepublishOnly": "npm run build",
    "docs": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "peerDependencies": {
    "react": ">=17.0.0",
    "react-dom": ">=17.0.0"
  },
  "dependencies": {
    "ajv": "^8.18.0",
    "ajv-keywords": "^5.1.0",
    "prettier": "^3.8.1",
    "react-router-dom": "^7.13.1",
    "schema-utils": "^4.3.3",
    "shiki": "^4.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/browser-playwright": "^4.0.18",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "playwright": "^1.58.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.0",
    "vitepress": "^1.6.4",
    "vitest": "^4.0.18"
  }
}
